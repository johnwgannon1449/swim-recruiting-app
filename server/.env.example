# ─────────────────────────────────────────────────────────────────
# Lesson Plan Analyzer — Server Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── Database ──────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/lesson_plan_analyzer

# ── Authentication ────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d

# ── CORS ──────────────────────────────────────────────────────────
CLIENT_URL=http://localhost:5173

# ── AI APIs ───────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
CLAUDE_MODEL=claude-sonnet-4-6

# ── Storage: AWS S3 or Cloudflare R2 (optional) ───────────────────
# Leave all STORAGE_* blank to disable cloud PDF storage.
# When configured, PDFs are generated server-side and stored here.
STORAGE_BUCKET=your-bucket-name
STORAGE_REGION=us-east-1
STORAGE_KEY_ID=your-access-key-id
STORAGE_SECRET_KEY=your-secret-access-key
# Cloudflare R2 / MinIO only — omit for AWS S3:
# STORAGE_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com

# ── Freemium / Usage Limits ────────────────────────────────────────
# Monthly lesson analysis limit per teacher (999 = tracking only, no enforcement)
MONTHLY_LESSON_LIMIT=999
